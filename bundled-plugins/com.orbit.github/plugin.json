{
  "schemaVersion": 1,
  "hostApiVersion": "^1.0.0",
  "id": "com.orbit.github",
  "name": "GitHub",
  "version": "0.1.2",
  "description": "Bundled flagship plugin: clone repos, open PRs. Bring your own classic GitHub OAuth App (paste client_id + client_secret in the OAuth tab).",
  "author": "Orbit",
  "license": "MIT",
  "icon": "assets/logo.svg",
  "runtime": {
    "type": "mcp-stdio",
    "command": "node",
    "args": ["server.js"]
  },
  "permissions": {
    "network": ["api.github.com", "github.com"],
    "oauth": ["github"]
  },
  "tools": [
    {
      "name": "clone_repo",
      "description": "Clone a GitHub repo into the agent workspace.",
      "riskLevel": "moderate",
      "inputSchema": {
        "type": "object",
        "required": ["repo"],
        "properties": {
          "repo": { "type": "string", "description": "owner/name" }
        }
      }
    },
    {
      "name": "create_pr",
      "description": "Open a pull request on a GitHub repo.",
      "riskLevel": "moderate",
      "inputSchema": {
        "type": "object",
        "required": ["repo", "title", "head", "base"],
        "properties": {
          "repo": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "head": { "type": "string" },
          "base": { "type": "string" }
        }
      }
    }
  ],
  "oauthProviders": [
    {
      "id": "github",
      "name": "GitHub",
      "authorizationUrl": "https://github.com/login/oauth/authorize",
      "tokenUrl": "https://github.com/login/oauth/access_token",
      "scopes": ["repo", "read:org"],
      "clientType": "confidential",
      "redirectUri": "http://127.0.0.1:47821/oauth/callback"
    }
  ]
}
