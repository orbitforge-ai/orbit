{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbit.dev/plugins/plugin.schema.json",
  "title": "Orbit Plugin Manifest",
  "$defs": {
    "secretSpec": {
      "type": "object",
      "required": ["key", "envVar", "displayName"],
      "properties": {
        "key": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "envVar": {
          "type": "string",
          "pattern": "^[A-Z_][A-Z0-9_]*$",
          "description": "Environment variable name injected into the plugin subprocess."
        },
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "placeholder": { "type": "string" }
      }
    },
    "workflowTriggerSpec": {
      "type": "object",
      "required": ["kind", "displayName"],
      "properties": {
        "kind": { "type": "string" },
        "displayName": { "type": "string" },
        "icon": { "type": "string" },
        "configSchema": { "type": "object" },
        "outputSchema": { "type": "object" },
        "subscriptionTool": { "type": "string" }
      }
    },
    "workflowNodeFieldOptionSpec": {
      "type": "object",
      "required": ["field", "sourceTool", "format"],
      "properties": {
        "field": { "type": "string" },
        "sourceTool": { "type": "string" },
        "format": { "type": "string" }
      }
    },
    "workflowNodeSpec": {
      "type": "object",
      "required": ["kind", "displayName", "tool"],
      "properties": {
        "kind": { "type": "string" },
        "displayName": { "type": "string" },
        "icon": { "type": "string" },
        "tool": { "type": "string" },
        "fieldOptions": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflowNodeFieldOptionSpec" }
        },
        "inputSchema": { "type": "object" },
        "outputSchema": { "type": "object" }
      }
    },
    "uiSidebarItemSpec": {
      "type": "object",
      "required": ["id", "label", "view"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "label": { "type": "string" },
        "icon": { "type": "string" },
        "view": { "type": "string" }
      }
    },
    "uiSurfaceActionSpec": {
      "type": "object",
      "required": ["id", "surface", "resolveTool"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "surface": { "type": "string", "enum": ["mainSidebar", "workspaceBrowser"] },
        "resolveTool": { "type": "string" }
      }
    },
    "uiEntityDetailTabSpec": {
      "type": "object",
      "required": ["targetEntity", "id", "label", "renderTool"],
      "properties": {
        "targetEntity": { "type": "string" },
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "label": { "type": "string" },
        "renderTool": { "type": "string" }
      }
    },
    "uiAgentChatActionSpec": {
      "type": "object",
      "required": ["id", "label", "tool"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "label": { "type": "string" },
        "tool": { "type": "string" }
      }
    },
    "uiSlashCommandSpec": {
      "type": "object",
      "required": ["name", "description", "tool"],
      "properties": {
        "name": { "type": "string", "pattern": "^/.+" },
        "description": { "type": "string" },
        "tool": { "type": "string" }
      }
    },
    "uiSettingsPanelSpec": {
      "type": "object",
      "required": ["id", "label", "renderTool"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "label": { "type": "string" },
        "renderTool": { "type": "string" }
      }
    }
  },
  "type": "object",
  "required": ["schemaVersion", "hostApiVersion", "id", "name", "version", "runtime"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "integer", "enum": [1] },
    "hostApiVersion": { "type": "string", "description": "Semver range. V1 host API is 1.0.0." },
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+(\\.[a-zA-Z0-9_-]+){1,}$",
      "description": "Reverse-DNS identifier."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "license": { "type": "string" },
    "icon": {
      "type": "string",
      "description": "Path to a plugin logo image, relative to the plugin root."
    },
    "runtime": {
      "type": "object",
      "required": ["type", "command"],
      "properties": {
        "type": { "type": "string", "enum": ["mcp-stdio"] },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "workingDir": { "type": "string" },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
          "description": { "type": "string" },
          "riskLevel": { "type": "string", "enum": ["safe", "moderate", "dangerous"] },
          "inputSchema": {}
        }
      }
    },
    "entityTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "schema"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
          "displayName": { "type": "string" },
          "icon": { "type": "string" },
          "schema": { "type": "object" },
          "relations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "to"],
              "properties": {
                "name": { "type": "string" },
                "to": { "type": "string" },
                "cardinality": { "type": "string", "enum": ["one", "many"] }
              }
            }
          },
          "listFields": { "type": "array", "items": { "type": "string" } },
          "titleField": { "type": "string" },
          "indexedFields": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "oauthProviders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "authorizationUrl", "tokenUrl"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
          "name": { "type": "string" },
          "authorizationUrl": { "type": "string", "format": "uri" },
          "tokenUrl": { "type": "string", "format": "uri" },
          "scopes": { "type": "array", "items": { "type": "string" } },
          "clientType": { "type": "string", "enum": ["public", "confidential"] },
          "redirectUri": { "type": "string" }
        }
      }
    },
    "secrets": {
      "type": "array",
      "items": { "$ref": "#/$defs/secretSpec" }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "network": { "type": "array", "items": { "type": "string" } },
        "filesystem": { "type": "array", "items": { "type": "string" } },
        "oauth": { "type": "array", "items": { "type": "string" } },
        "coreEntities": { "type": "array", "items": { "type": "string" } }
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "subscribe": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "session.started",
              "session.ended",
              "agent.tool.before_call",
              "agent.tool.after_call",
              "entity.work_item.after_create",
              "entity.work_item.after_complete",
              "entity.work_item.before_delete",
              "oauth.connected",
              "plugin.enabled",
              "plugin.disabled"
            ]
          }
        }
      }
    },
    "workflow": {
      "type": "object",
      "properties": {
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflowTriggerSpec" }
        },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflowNodeSpec" }
        }
      }
    },
    "ui": {
      "type": "object",
      "properties": {
        "sidebarItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/uiSidebarItemSpec" }
        },
        "surfaceActions": {
          "type": "array",
          "items": { "$ref": "#/$defs/uiSurfaceActionSpec" }
        },
        "entityDetailTabs": {
          "type": "array",
          "items": { "$ref": "#/$defs/uiEntityDetailTabSpec" }
        },
        "agentChatActions": {
          "type": "array",
          "items": { "$ref": "#/$defs/uiAgentChatActionSpec" }
        },
        "slashCommands": {
          "type": "array",
          "items": { "$ref": "#/$defs/uiSlashCommandSpec" }
        },
        "settingsPanels": {
          "type": "array",
          "items": { "$ref": "#/$defs/uiSettingsPanelSpec" }
        }
      }
    }
  }
}
